<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300" prefWidth="400" spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.diegoalegil.garageos.controllers.PrincipalController">
   <children>
      <TextField fx:id="matriculaField" promptText="Matrícula" />
      <TextField fx:id="marcaField" promptText="Marca" />
      <TextField fx:id="modeloField" promptText="Modelo" />
      <TextField fx:id="anioField" promptText="Año" />
      <TextField fx:id="kilometrajeField" promptText="Kilometraje" />
      <ComboBox fx:id="propulsionCombo" prefWidth="150.0" promptText="Propulsión" />
      <HBox alignment="CENTER" spacing="100.0">
         <children>
            <Button fx:id="cancelarButton" mnemonicParsing="false" onAction="#cancelarEdicion" text="Cancelar" />
            <Button fx:id="accionButton" mnemonicParsing="false" onAction="#guardarVehiculo" text="Guardar" />
            <Button fx:id="eliminarButton" mnemonicParsing="false" onAction="#eliminarVehiculo" text="Eliminar" />
         </children>
      </HBox>
      <Label fx:id="resultadoLabel" />
      <ListView fx:id="vehiculosList" prefHeight="150.0" prefWidth="200.0" />
   </children>
    
</VBox>
