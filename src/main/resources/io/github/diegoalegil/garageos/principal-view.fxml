<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="760.0" prefWidth="1120.0" spacing="16.0" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.diegoalegil.garageos.controllers.PrincipalController">
   <children>
      <HBox alignment="CENTER_LEFT" prefWidth="1060.0" spacing="12.0" styleClass="app-toolbar">
         <children>
            <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
               <image>
                  <Image url="@assets/app-icon.png" />
               </image>
            </ImageView>
            <Label styleClass="app-title" text="GarageOS" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dashboard-bar">
               <children>
                  <VBox alignment="CENTER_LEFT" styleClass="dashboard-card">
                     <children>
                        <Label styleClass="dashboard-label" text="Vehículos" />
                        <Label fx:id="dashboardVehiculosLabel" styleClass="dashboard-value" text="0" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" styleClass="dashboard-card">
                     <children>
                        <Label styleClass="dashboard-label" text="Mantenimientos" />
                        <Label fx:id="dashboardMantenimientosLabel" styleClass="dashboard-value" text="0" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" styleClass="dashboard-card">
                     <children>
                        <Label styleClass="dashboard-label" text="Invertido" />
                        <Label fx:id="dashboardInversionLabel" styleClass="dashboard-value" text="0,00 €" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" styleClass="dashboard-card-wide">
                     <children>
                        <Label styleClass="dashboard-label" text="Último movimiento" />
                        <Label fx:id="dashboardUltimoLabel" styleClass="dashboard-value" text="Sin historial" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="20.0" styleClass="content-row">
         <children>
            <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="540.0" spacing="14.0" styleClass="panel">
               <children>
                  <Label styleClass="section-title" text="Vehículos" />
                  <Label fx:id="modoVehiculoLabel" styleClass="mode-label" text="Alta de vehículo" />
                  <TextField fx:id="buscarVehiculoField" promptText="Buscar por matrícula, marca, modelo o propulsión" />
                  <TextField fx:id="matriculaField" promptText="Matrícula" />
                  <TextField fx:id="marcaField" promptText="Marca" />
                  <TextField fx:id="modeloField" promptText="Modelo" />
                  <TextField fx:id="anioField" promptText="Año" />
                  <TextField fx:id="kilometrajeField" promptText="Kilometraje" />
                  <ComboBox fx:id="propulsionCombo" prefWidth="150.0" promptText="Propulsión" />
                  <HBox alignment="CENTER" spacing="44.0">
                     <children>
                        <Button fx:id="cancelarButton" mnemonicParsing="false" onAction="#cancelarEdicion" prefWidth="96.0" styleClass="secondary-button" text="Cancelar" />
                        <Button fx:id="accionButton" mnemonicParsing="false" onAction="#guardarVehiculo" prefWidth="96.0" styleClass="primary-button" text="Guardar" />
                        <Button fx:id="eliminarButton" mnemonicParsing="false" onAction="#eliminarVehiculo" prefWidth="96.0" styleClass="danger-button" text="Eliminar" />
                     </children>
                  </HBox>
                  <Label fx:id="resultadoLabel" styleClass="status-label" />
                  <Label fx:id="resumenVehiculosLabel" styleClass="summary-label" />
                  <ListView fx:id="vehiculosList" prefHeight="245.0" prefWidth="200.0" />
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="500.0" spacing="10.0" styleClass="panel">
               <children>
                  <Label styleClass="section-title" text="Mantenimientos" />
                  <VBox alignment="CENTER_LEFT" spacing="4.0" styleClass="vehicle-context-card">
                     <children>
                        <Label fx:id="vehiculoActivoLabel" styleClass="vehicle-context-title" text="Selecciona un vehículo" />
                        <Label fx:id="vehiculoActivoDetalleLabel" styleClass="vehicle-context-detail" text="El historial se mostrará aquí" />
                        <Label fx:id="proximaRevisionLabel" styleClass="vehicle-context-hint" text="Próxima revisión: --" />
                     </children>
                  </VBox>
                  <Label fx:id="resumenMantenimientosLabel" styleClass="summary-label" />
                  <Label fx:id="ultimoMantenimientoLabel" styleClass="detail-label" />
                  <TextField fx:id="fechaMantenimientoField" promptText="Fecha (YYYY-MM-DD)" />
                  <TextField fx:id="descripcionMantenimientoField" promptText="Descripción" />
                  <TextField fx:id="costeMantenimientoField" promptText="Coste" />
                  <TextField fx:id="kmMantenimientoField" promptText="Km en la revisión" />
                  <HBox alignment="CENTER" spacing="16.0">
                     <children>
                        <Button fx:id="cancelarMantenimientoButton" mnemonicParsing="false" onAction="#cancelarEdicionMantenimiento" prefWidth="90.0" styleClass="secondary-button" text="Cancelar" />
                        <Button fx:id="guardarMantenimientoButton" mnemonicParsing="false" onAction="#guardarMantenimiento" prefWidth="150.0" styleClass="primary-button" text="Guardar mant." />
                        <Button fx:id="eliminarMantenimientoButton" mnemonicParsing="false" onAction="#eliminarMantenimiento" prefWidth="90.0" styleClass="danger-button" text="Eliminar" />
                     </children>
                  </HBox>
                  <ListView fx:id="mantenimientosList" prefHeight="315.0" prefWidth="200.0" />
                  <Label fx:id="resultadoMantenimientoLabel" styleClass="status-label" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
